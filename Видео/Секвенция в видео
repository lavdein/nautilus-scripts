#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

img_files=()
for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    ext="${f##*.}"; ext="${ext,,}"
    [[ "$ext" =~ ^(png|jpg|jpeg|webp|tiff|tif|bmp)$ ]] && img_files+=("$f")
done

if [ ${#img_files[@]} -lt 2 ]; then
    notify-send "Секвенция в видео" "Выберите минимум 2 изображения." -i dialog-error
    exit 1
fi

fps=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Частота кадров" \
    "Сколько кадров в секунду в итоговом видео" \
    "12 fps|Анимации, медленное движение" \
    "24 fps|Кино-стандарт" \
    "25 fps|PAL / европейский стандарт" \
    "30 fps|Видео, веб" \
    "60 fps|Плавное движение, геймплей") || exit 0

fmt=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Формат видео" \
    "Контейнер и качество итогового файла" \
    "MP4|H.264, широкая совместимость" \
    "MKV|H.264, чуть лучше качество") || exit 0

fps_val="${fps%% *}"
fmt="${fmt,,}"

PROGRESS_FILE=$(mktemp /tmp/seq2vid-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/ffmpeg_sequence_worker.py" \
    "$PROGRESS_FILE" "$fps_val" "$fmt" "${img_files[@]}" \
    >/tmp/seq2vid-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE"
