#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

IFS=$'\n' read -ra files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
input="${files[0]}"

if [ -z "$input" ]; then
    notify-send "Информация о видео" "Файл не выбран." -i dialog-error
    exit 1
fi

ffprobe -v quiet -print_format json -show_format -show_streams "$input" 2>/dev/null \
| "$PYTHON" -c "
import json, sys

data = json.load(sys.stdin)
fmt     = data.get('format', {})
streams = data.get('streams', [])
lines   = []

lines.append('Файл: ' + fmt.get('filename', '').split('/')[-1])

dur = float(fmt.get('duration', 0))
hh, rem = divmod(int(dur), 3600)
mm, ss  = divmod(rem, 60)
lines.append(f'Длительность: {hh:02d}:{mm:02d}:{ss:02d}')

size = int(fmt.get('size', 0))
if size > 1024**3:
    lines.append(f'Размер: {size/1024**3:.2f} ГБ')
elif size > 1024**2:
    lines.append(f'Размер: {size/1024**2:.1f} МБ')
else:
    lines.append(f'Размер: {size/1024:.0f} КБ')

br = int(fmt.get('bit_rate', 0))
lines.append(f'Общий битрейт: {br//1000} кбит/с')

for s in streams:
    lines.append('')
    if s.get('codec_type') == 'video':
        lines.append('[ Видео ]')
        lines.append('  Кодек:      ' + s.get('codec_name','?').upper())
        lines.append(f'  Разрешение: {s.get(\"width\",\"?\")}×{s.get(\"height\",\"?\")}')
        r = s.get('r_frame_rate','0/1').split('/')
        fps = round(int(r[0])/int(r[1]),2) if len(r)==2 and int(r[1])>0 else 0
        lines.append(f'  FPS:        {fps}')
        vbr = int(s.get('bit_rate', 0))
        if vbr: lines.append(f'  Битрейт:    {vbr//1000} кбит/с')
        pix = s.get('pix_fmt','')
        if pix: lines.append(f'  Пиксели:    {pix}')
    elif s.get('codec_type') == 'audio':
        lines.append('[ Аудио ]')
        lines.append('  Кодек:    ' + s.get('codec_name','?').upper())
        ch  = s.get('channels','?')
        chl = s.get('channel_layout','')
        lines.append(f'  Каналы:   {ch}' + (f' ({chl})' if chl else ''))
        lines.append(f'  Частота:  {s.get(\"sample_rate\",\"?\")} Гц')
        abr = int(s.get('bit_rate', 0))
        if abr: lines.append(f'  Битрейт:  {abr//1000} кбит/с')

print('\n'.join(lines))
" | "$PYTHON" "$SCRIPTS_ROOT/.meta/show_info.py" "Информация о видео"
