#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Сжать видео" "Файлы не выбраны." -i dialog-error
    exit 1
fi

preset=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Сжать видео" \
    "Выберите степень сжатия" \
    "Высокое качество|Файл ~40-50% меньше" \
    "Баланс|Файл ~60-70% меньше" \
    "Для интернета|Файл ~75-85% меньше" \
    "Минимальный размер|Заметная потеря качества") || exit 0

case "$preset" in
    "Высокое качество") crf=20; speed="slow"     ;;
    "Баланс")           crf=26; speed="medium"   ;;
    "Для интернета")    crf=30; speed="fast"      ;;
    "Минимальный размер") crf=36; speed="veryfast" ;;
esac

PROGRESS_FILE=$(mktemp /tmp/compress-vid-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/ffmpeg_compress_worker.py" \
    "$PROGRESS_FILE" "$crf" "$speed" "${files[@]}" \
    >/tmp/compress-vid-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE"
