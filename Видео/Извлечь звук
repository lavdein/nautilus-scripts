#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Извлечь звук" "Файлы не выбраны." -i dialog-error
    exit 1
fi

format=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Извлечь звук" \
    "Выберите формат аудио" \
    "MP3|Универсальный, ~192 кбит/с" \
    "AAC|Хорошее качество, компактный" \
    "FLAC|Без потерь, большой размер" \
    "OGG|Свободный формат Vorbis" \
    "WAV|Без потерь, несжатый") || exit 0

format="${format,,}"

PROGRESS_FILE=$(mktemp /tmp/extract-audio-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/ffmpeg_audio_worker.py" \
    "$PROGRESS_FILE" "$format" "${files[@]}" \
    >/tmp/extract-audio-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE"
