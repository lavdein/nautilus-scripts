#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

video_files=()
for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    ext="${f##*.}"; ext="${ext,,}"
    [[ "$ext" =~ ^(mp4|mkv|avi|mov|webm|flv|ts|m2ts|wmv)$ ]] && video_files+=("$f")
done

if [ ${#video_files[@]} -eq 0 ]; then
    notify-send "Видео в секвенцию" "Не выбрано ни одного видео-файла." -i dialog-error
    exit 1
fi

OPTIONS=$("$PYTHON" "$SCRIPTS_ROOT/.meta/form.py" \
    "Видео в секвенцию" \
    "${#video_files[@]} файл(ов)" \
    "Извлечь" \
    "Частота:1 кадр/с|2 кадра/с|5 кадров/с|10 кадров/с|Каждый кадр" \
    "Формат:PNG|JPG|WEBP") || exit 0

fps=$(echo "$OPTIONS" | cut -d'|' -f1)
fmt=$(echo "$OPTIONS" | cut -d'|' -f2)
fmt="${fmt,,}"

case "$fps" in
    "1 кадр/с")    fps_val="1"  ;;
    "2 кадра/с")   fps_val="2"  ;;
    "5 кадров/с")  fps_val="5"  ;;
    "10 кадров/с") fps_val="10" ;;
    "Каждый кадр") fps_val=""   ;;
esac

PROGRESS_FILE=$(mktemp /tmp/vid2seq-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/ffmpeg_extract_worker.py" \
    "$PROGRESS_FILE" "$fps_val" "$fmt" "${video_files[@]}" \
    >/tmp/vid2seq-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Видео в секвенцию"
