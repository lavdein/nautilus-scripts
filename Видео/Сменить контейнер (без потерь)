#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Сменить контейнер" "Файлы не выбраны." -i dialog-error
    exit 1
fi

format=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Сменить контейнер" \
    "Перепаковка без перекодирования — качество 1 в 1. Может не сработать если кодек несовместим с контейнером." \
    "MP4|Широкая совместимость (H.264 / AAC)" \
    "MKV|Matroska — принимает любые кодеки" \
    "MOV|Apple QuickTime / Final Cut" \
    "AVI|Старый формат Windows") || exit 0

format="${format,,}"

# Skip files already in the target format
valid_files=()
for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    ext="${f##*.}"
    [ "${ext,,}" != "$format" ] && valid_files+=("$f")
done

if [ ${#valid_files[@]} -eq 0 ]; then
    notify-send "Сменить контейнер" "Все файлы уже в формате ${format^^}." -i dialog-information
    exit 0
fi

PROGRESS_FILE=$(mktemp /tmp/ffremux-XXXXX)

export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/ffmpeg_remux_worker.py" \
    "$PROGRESS_FILE" "$format" "${valid_files[@]}" \
    >/tmp/ffremux-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/Утилиты/.whisper/indicator.py" "$PROGRESS_FILE"
