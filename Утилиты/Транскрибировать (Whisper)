#!/usr/bin/env bash
set -eo pipefail

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
SCRIPTS_ROOT="$(dirname "$SCRIPT_DIR")"
PYTHON_VENV="/usr/bin/python3"
PYTHON_WORK="$SCRIPT_DIR/.whisper/env/bin/python3"
WORKER="$SCRIPT_DIR/.whisper/transcribe.py"

AUDIO_EXT="mp3|wav|flac|ogg|m4a|aac|opus|wma"
VIDEO_EXT="mp4|mkv|avi|mov|webm|flv|ts|m2ts"

FILES=()
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    ext="${f##*.}"; ext="${ext,,}"
    [[ "$ext" =~ ^($AUDIO_EXT|$VIDEO_EXT)$ ]] && FILES+=("$f")
done <<< "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}"

if [[ ${#FILES[@]} -eq 0 ]]; then
    notify-send "Транскрипция Whisper" "Не выбрано ни одного аудио или видео файла." -i dialog-error
    exit 1
fi

MODEL=$("$PYTHON_VENV" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Модель Whisper" \
    "${#FILES[@]} файл(ов) — чем больше модель, тем точнее" \
    "large-v3-turbo|Лучший баланс скорости и качества" \
    "large-v3|Максимальное качество, медленнее" \
    "medium|Среднее качество, быстро" \
    "small|Базовое качество, очень быстро" \
    "base|Минимальное качество, мгновенно" \
    "tiny|Черновик, только для теста") || exit 0

LANG=$("$PYTHON_VENV" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Язык аудио" \
    "Выберите язык или авто-определение" \
    "auto|Определить автоматически" \
    "ru|Русский" \
    "en|English" \
    "uk|Українська" \
    "de|Deutsch" \
    "fr|Français" \
    "es|Español" \
    "zh|中文" \
    "ja|日本語" \
    "ko|한국어" \
    "ar|العربية" \
    "tr|Türkçe" \
    "pl|Polski") || exit 0

FMT=$("$PYTHON_VENV" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Формат вывода" \
    "Какие файлы создать рядом с аудио" \
    "txt + srt|Текст и субтитры" \
    "только txt|Только текст" \
    "только srt|Только субтитры") || exit 0

DO_TXT=false; DO_SRT=false
[[ "$FMT" == "txt + srt"  ]] && DO_TXT=true && DO_SRT=true
[[ "$FMT" == "только txt" ]] && DO_TXT=true
[[ "$FMT" == "только srt" ]] && DO_SRT=true

PROGRESS_FILE=$(mktemp /tmp/whisper-progress-XXXXX)

export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

NVIDIA_LIBS=$(find "$SCRIPT_DIR/.whisper/env" -type d -name "lib" -path "*/nvidia/*/lib" 2>/dev/null | tr '\n' ':')
[[ -n "$NVIDIA_LIBS" ]] && export LD_LIBRARY_PATH="${NVIDIA_LIBS%:}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

nohup "$PYTHON_WORK" "$WORKER" \
    "$PROGRESS_FILE" "$MODEL" "$LANG" "$DO_TXT" "$DO_SRT" "${FILES[@]}" \
    >/tmp/whisper-worker.log 2>&1 &

exec "$PYTHON_VENV" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE"
