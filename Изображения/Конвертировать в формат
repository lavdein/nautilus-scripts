#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Конвертировать в формат" "Файлы не выбраны." -i dialog-error
    exit 1
fi

format=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Конвертировать в формат" \
    "Выберите формат вывода" \
    "PNG|Без потерь, поддержка прозрачности" \
    "JPG|Фото, малый размер" \
    "WEBP|Веб — малый размер и прозрачность" \
    "AVIF|Новый формат, лучшее сжатие" \
    "GIF|Анимация / совместимость" \
    "TIFF|Полиграфия / архив" \
    "ICO|Иконка Windows") || exit 0

format="${format,,}"
quality=""

if [ "$format" = "jpg" ]; then
    quality=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
        "Качество JPEG" \
        "Баланс между качеством и размером файла" \
        "95|Высокое — почти без потерь" \
        "85|Хорошее — рекомендуется" \
        "75|Среднее — меньше файл" \
        "60|Низкое — маленький файл") || exit 0
fi

if [ "$format" = "webp" ]; then
    quality=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
        "Качество WebP" \
        "Режим сжатия" \
        "lossless|Без потерь — больше файл" \
        "90|Высокое качество" \
        "80|Хорошее качество" \
        "70|Среднее качество") || exit 0
fi

PROGRESS_FILE=$(mktemp /tmp/img-convert-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_convert_worker.py" \
    "$PROGRESS_FILE" "$format" "$quality" "${files[@]}" \
    >/tmp/img-convert-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE"
