#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Конвертировать в формат" "Файлы не выбраны." -i dialog-error
    exit 1
fi

OPTIONS=$("$PYTHON" "$SCRIPTS_ROOT/.meta/form.py" \
    "Конвертировать в формат" \
    "${#files[@]} файл(ов)" \
    "Конвертировать" \
    "Формат:PNG|JPG|WEBP|AVIF|GIF|TIFF|ICO" \
    "@0=JPG|Качество:scale:1:100:85" \
    "@0=WEBP|Режим:lossless|90|80|70") || exit 0

format=$(echo "$OPTIONS"  | cut -d'|' -f1)
jpg_q=$(echo "$OPTIONS"   | cut -d'|' -f2)
webp_q=$(echo "$OPTIONS"  | cut -d'|' -f3)

format="${format,,}"
quality=""
[[ "$format" == "jpg" ]]  && quality="$jpg_q"
[[ "$format" == "webp" ]] && quality="$webp_q"

PROGRESS_FILE=$(mktemp /tmp/img-convert-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_convert_worker.py" \
    "$PROGRESS_FILE" "$format" "$quality" "${files[@]}" \
    >/tmp/img-convert-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Конвертировать в формат"
