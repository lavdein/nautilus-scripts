#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Изменить размер" "Файлы не выбраны." -i dialog-error
    exit 1
fi

OPTIONS=$("$PYTHON" "$SCRIPTS_ROOT/.meta/form.py" \
    "Изменить размер" \
    "${#files[@]} файл(ов)" \
    "Изменить" \
    "Тип:По проценту|По размеру" \
    "@0=По проценту|Процент:scale:10:300:50" \
    "@0=По размеру|Размер:1920x1080|1280x720|3840x2160|800x600|512x512|256x256") || exit 0

type=$(echo "$OPTIONS" | cut -d'|' -f1)
pct=$(echo "$OPTIONS"  | cut -d'|' -f2)
size=$(echo "$OPTIONS" | cut -d'|' -f3)

if [[ "$type" == "По проценту" ]]; then
    resize_arg="${pct}%"
    suffix="_${pct}pct"
else
    resize_arg="$size"
    suffix="_${size/x/_}"
fi

PROGRESS_FILE=$(mktemp /tmp/img-resize-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_resize_worker.py" \
    "$PROGRESS_FILE" "$resize_arg" "$suffix" "${files[@]}" \
    >/tmp/img-resize-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Изменить размер"
