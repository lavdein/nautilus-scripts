#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t all_files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${all_files[@]}"; do
    [ -z "$f" ] && continue
    ext="${f##*.}"; ext="${ext,,}"
    [[ "$ext" =~ ^(jpg|jpeg|png|webp|gif|tiff|tif|avif|heic|bmp|ico)$ ]] && files+=("$f")
done

if [ ${#files[@]} -eq 0 ]; then
    notify-send "Изображения" "Не выбрано ни одного изображения." -i dialog-error
    exit 1
fi

OPTIONS=$("$PYTHON" "$SCRIPTS_ROOT/.meta/form.py" \
    "Изображения" \
    "${#files[@]} файл(ов)" \
    "Применить" \
    "Операция:Конвертировать|Изменить размер|Оптимизировать" \
    "@0=Конвертировать|Формат:PNG|JPG|WEBP|AVIF|GIF|TIFF|ICO" \
    "@1=JPG|Качество JPG:scale:1:100:85" \
    "@1=WEBP|Режим WebP:lossless|90|80|70" \
    "@0=Изменить размер|Тип:По проценту|По размеру" \
    "@4=По проценту|Процент:scale:10:300:50" \
    "@4=По размеру|Размер:1920x1080|1280x720|3840x2160|800x600|512x512|256x256") || exit 0

op=$(echo "$OPTIONS"     | cut -d'|' -f1)
format=$(echo "$OPTIONS" | cut -d'|' -f2 | tr '[:upper:]' '[:lower:]')
jpg_q=$(echo "$OPTIONS"  | cut -d'|' -f3)
webp_q=$(echo "$OPTIONS" | cut -d'|' -f4)
r_type=$(echo "$OPTIONS" | cut -d'|' -f5)
pct=$(echo "$OPTIONS"    | cut -d'|' -f6)
size=$(echo "$OPTIONS"   | cut -d'|' -f7)

PROGRESS_FILE=$(mktemp /tmp/img-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

if [[ "$op" == "Конвертировать" ]]; then
    quality=""
    [[ "$format" == "jpg" ]]  && quality="$jpg_q"
    [[ "$format" == "webp" ]] && quality="$webp_q"
    nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_convert_worker.py" \
        "$PROGRESS_FILE" "$format" "$quality" "${files[@]}" \
        >/tmp/img-worker.log 2>&1 &

elif [[ "$op" == "Изменить размер" ]]; then
    if [[ "$r_type" == "По проценту" ]]; then
        resize_arg="${pct}%"
        suffix="_${pct}pct"
    else
        resize_arg="$size"
        suffix="_${size/x/_}"
    fi
    nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_resize_worker.py" \
        "$PROGRESS_FILE" "$resize_arg" "$suffix" "${files[@]}" \
        >/tmp/img-worker.log 2>&1 &

else
    nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/magick_optimize_worker.py" \
        "$PROGRESS_FILE" "${files[@]}" \
        >/tmp/img-worker.log 2>&1 &
fi

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Изображения"
