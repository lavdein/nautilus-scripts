#!/usr/bin/env bash
# Copy full file path(s) to clipboard

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

paths=""
count=0
for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    paths="$paths$f"$'\n'
    count=$((count + 1))
done
paths="${paths%$'\n'}"

if [ $count -eq 0 ]; then
    notify-send "Копировать путь" "Файлы не выбраны."
    exit 1
fi

if command -v wl-copy &>/dev/null; then
    printf '%s' "$paths" | wl-copy
elif command -v xclip &>/dev/null; then
    printf '%s' "$paths" | xclip -selection clipboard
elif command -v xsel &>/dev/null; then
    printf '%s' "$paths" | xsel --clipboard --input
else
    notify-send "Копировать путь" "Не найден wl-copy / xclip / xsel."
    exit 1
fi

if [ $count -eq 1 ]; then
    notify-send "Путь скопирован" "$paths"
else
    notify-send "Пути скопированы" "$count файла(ов)"
fi
