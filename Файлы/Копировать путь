#!/bin/bash
# Copy full file path(s) to clipboard

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

paths=""
count=0
for f in "${files[@]}"; do
    [ -z "$f" ] && continue
    paths="$paths$f"$'\n'
    count=$((count + 1))
done
paths="${paths%$'\n'}"

if [ $count -eq 0 ]; then
    zenity --error --text="Файлы не выбраны." --width=280
    exit 1
fi

if command -v wl-copy &>/dev/null; then
    printf '%s' "$paths" | wl-copy
elif command -v xclip &>/dev/null; then
    printf '%s' "$paths" | xclip -selection clipboard
elif command -v xsel &>/dev/null; then
    printf '%s' "$paths" | xsel --clipboard --input
else
    zenity --error --text="Не найден инструмент буфера обмена (wl-copy/xclip/xsel)." --width=340
    exit 1
fi

if [ $count -eq 1 ]; then
    msg="Путь скопирован:\n$paths"
else
    msg="Скопировано путей: $count"
fi

zenity --info --title="Путь скопирован" --text="$msg" --timeout=2 --width=300 2>/dev/null
