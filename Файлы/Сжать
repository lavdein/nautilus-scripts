#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t all_files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
files=()
for f in "${all_files[@]}"; do [ -n "$f" ] && files+=("$f"); done

if [ ${#files[@]} -eq 0 ]; then
    notify-send "Сжать" "Файлы не выбраны." -i dialog-error
    exit 1
fi

preset=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Сжать" \
    "${#files[@]} файл(ов)" \
    "Осторожно|Минимальные потери качества" \
    "Баланс|Хорошее сжатие, приемлемое качество" \
    "Агрессивно|Максимальное сжатие") || exit 0

PROGRESS_FILE=$(mktemp /tmp/compress-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/compress_all_worker.py" \
    "$PROGRESS_FILE" "$preset" "${files[@]}" \
    >/tmp/compress-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Сжать"
