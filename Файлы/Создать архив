#!/bin/bash
# Create zip / tar.gz / tar.xz archive from selected files

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    zenity --error --title="Создать архив" --text="Файлы не выбраны." --width=300
    exit 1
fi

parent=$(dirname "${files[0]}")

default_name=$(basename "${files[0]}")
[ ${#files[@]} -gt 1 ] && default_name="архив"

name=$(zenity --entry \
    --title="Создать архив" \
    --text="Имя архива (без расширения):" \
    --entry-text="$default_name" \
    --width=380 2>/dev/null)
[ -z "$name" ] && exit 0

format=$(zenity --list \
    --title="Создать архив" \
    --text="Формат:" \
    --radiolist \
    --column="" --column="Формат" --column="Описание" \
    TRUE  "zip"    "ZIP — универсальный, открывается везде" \
    FALSE "tar.gz" "TAR.GZ — хорошее сжатие, быстро" \
    FALSE "tar.xz" "TAR.XZ — максимальное сжатие, медленнее" \
    --width=420 --height=260 2>/dev/null)
[ -z "$format" ] && exit 0

output="$parent/$name.$format"
c=1
while [ -f "$output" ]; do
    output="$parent/${name}_${c}.$format"
    c=$((c + 1))
done

names=()
for f in "${files[@]}"; do
    [ -n "$f" ] && names+=("$(basename "$f")")
done

cd "$parent" || exit 1

case "$format" in
    zip)    zip -r "$output" "${names[@]}" 2>/tmp/archive_err.txt ;;
    tar.gz) tar -czf "$output" "${names[@]}" 2>/tmp/archive_err.txt ;;
    tar.xz) tar -cJf "$output" "${names[@]}" 2>/tmp/archive_err.txt ;;
esac

if [ $? -eq 0 ]; then
    size=$(du -sh "$output" | cut -f1)
    zenity --info --title="Архив создан" \
        --text="$(basename "$output")\nРазмер: $size" --width=320
else
    zenity --error --title="Ошибка" \
        --text="Не удалось создать архив.\nПодробности: /tmp/archive_err.txt" --width=360
fi
