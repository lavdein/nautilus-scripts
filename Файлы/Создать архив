#!/usr/bin/env bash
set -eo pipefail

SCRIPTS_ROOT="$(dirname "$(dirname "$(realpath "$0")")")"
PYTHON="/usr/bin/python3"

mapfile -t files <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"

if [ ${#files[@]} -eq 0 ] || [ -z "${files[0]}" ]; then
    notify-send "Создать архив" "Файлы не выбраны." -i dialog-error
    exit 1
fi

parent=$(dirname "${files[0]}")

default_name=$(basename "${files[0]}")
[ ${#files[@]} -gt 1 ] && default_name="архив"

name=$(zenity --entry \
    --title="Создать архив" \
    --text="Имя архива (без расширения):" \
    --entry-text="$default_name" \
    --width=380 2>/dev/null) || exit 0
[ -z "$name" ] && exit 0

format=$("$PYTHON" "$SCRIPTS_ROOT/.meta/pick.py" \
    "Формат архива" \
    "Выберите формат сжатия" \
    "zip|Универсальный, открывается везде" \
    "tar.gz|Хорошее сжатие, быстро" \
    "tar.xz|Максимальное сжатие, медленнее") || exit 0

output="$parent/$name.$format"
c=1
while [ -f "$output" ]; do
    output="$parent/${name}_${c}.$format"
    c=$((c + 1))
done

names=()
for f in "${files[@]}"; do
    [ -n "$f" ] && names+=("$(basename "$f")")
done

PROGRESS_FILE=$(mktemp /tmp/archive-XXXXX)
export GI_TYPELIB_PATH="/usr/lib64/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"

nohup "$PYTHON" "$SCRIPTS_ROOT/.meta/archive_worker.py" \
    "$PROGRESS_FILE" "$output" "$format" "${names[@]}" \
    >/tmp/archive-worker.log 2>&1 &

exec "$PYTHON" "$SCRIPTS_ROOT/.meta/indicator.py" "$PROGRESS_FILE" "Создать архив"
